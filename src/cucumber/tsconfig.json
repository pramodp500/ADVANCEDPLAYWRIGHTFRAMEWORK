{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "@cucumber/cucumber"],
    "paths": {
      "@steps/*": ["./steps/*"],
      "@support/*": ["./support/*"],
      "@features/*": ["./feature/*"],
      "@hooks/*": ["./hooks/*"]
    },
    "baseUrl": "."
  },
  "include": ["steps/**/*.ts", "support/**/*.ts", "hooks/**/*.ts", "feature/*.feature"],
  "exclude": ["node_modules", "dist"]
}
